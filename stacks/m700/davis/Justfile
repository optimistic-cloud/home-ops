set shell := ["bash", "-eoux", "pipefail", "-c"]

set dotenv-load

help:
  just --list --list-submodules

####################################
######## DOCKER             ########
####################################

[group('docker')]
[doc('Start the stack')]
up:
  docker compose up -d --remove-orphans

[group('docker')]
[doc('Stop the stack')]
down:
  docker compose down --remove-orphans

[group('docker')]
[doc('Restart application stack')]
restart: down && up

[group('docker')]
[doc('Get logs for the application')]
logs:
  docker compose logs -f

[group("docker")]
[doc('List data of the application')]
ls-davis-data:
  just ls-volume-data davis-data

[group("docker")]
[doc('List docker volume data')]
[private]
ls-volume-data export_path:
  docker run --rm -v {{export_path}}:/data:ro alpine ls -la /data

[group('application')]
[doc('Migrate database')]
migrate:
  docker exec -it davis sh -c "APP_ENV=prod bin/console doctrine:migrations:migrate --no-interaction"

[group('application')]
[doc('Get logs for the application')]
davis-log-tail:
    docker exec -it davis tail /var/www/davis/var/log/prod.log

####################################
######## BACKUP             ########
####################################

[group("backup")]
setup-backup: cleanup-backup
  mkdir -p ${BACKUP_WORK_DIR}

[group("backup")]
cleanup-backup:
  rm -rf ${BACKUP_WORK_DIR}

[group("backup")]
backup target: setup-backup && cleanup-backup
  #!/usr/bin/env nu
  use std/log
  
  let target = "{{target}}"

  let hc_url = $"($env.HC_URL)-($target)"
  let run_id = (random uuid)

  let logfile = $"($env.BACKUP_WORK_DIR)/($target).backup.log"

  try {
    ^curl -sSX POST $"($hc_url)/start?rid=($run_id)&create=1"

    let result = (
      nu backup.nu 
        --restic-env-file $"($target).restic.env" 
        --restic-password-file $"($target).restic.password" 
        --working-dir $env.BACKUP_WORK_DIR 
        | complete
      )
    $"($result.stdout)($result.stderr)" | save $logfile
    if $result.exit_code != 0 {
      error make {msg: $"Backup script exited with code ($result.exit_code)"}
    }

    if (($logfile | path exists) and ((ls $logfile | get size.0) == 0B)) {
      error make {msg: "Backup failed, log file ($logfile) is empty"}
    }
    ^curl -sSX POST $"($hc_url)/0?rid=($run_id)" -H "Content-Type: text/plain" --data-binary $"@($logfile)"
  } catch { |err|
    log error $"Backup failed: ($err.msg)"
    $err.msg | save --append $logfile
    ^curl -sSX POST $"($hc_url)/fail?rid=($run_id)" -H "Content-Type: text/plain" --data-binary $"@($logfile)"
    error make $err
  }

[group("backup")]
restore backup_target snapshot_id="latest":
  #!/usr/bin/env bash
  restore_data_dir="${BACKUP_RESTORE_DATA_DIR:?BACKUP_RESTORE_DATA_DIR is required}"
  mkdir -p "${restore_data_dir}"
  just restic-restore {{backup_target}} {{snapshot_id}}

####################################
######## RESTIC             ########
####################################

[group('restic')]
[doc('Init repository')]
restic-init backup_target:
  just _restic-run {{backup_target}} init

[group('restic')]
[doc('Restore data')]
[private]
restic-restore backup_target snapshot_id:
  just _restic-run {{backup_target}} restore {{snapshot_id}} --target /restore-data

[group('restic')]
[doc('Get snapshots')]
restic-snapshots backup_target count="5":
  just _restic-run {{backup_target}} --quiet snapshots --latest {{count}}

[group('restic')]
[doc('List files in the latest snapshot')]
restic-ls backup_target snapshot_id="latest":
  just _restic-run {{backup_target}} --quiet ls {{snapshot_id}}

[group('restic')]
[doc('Get stats of the repository')]
restic-stats backup_target:
  just _restic-run {{backup_target}} stats --mode raw-data

[group('restic')]
[doc('Unlock repository')]
restic-unlock backup_target:
  just _restic-run {{backup_target}} --quiet unlock

[group('restic')]
[doc('Prune snapshots')]
restic-prune backup_target:
  just _restic-run {{backup_target}} --quiet prune

[group('restic')]
[private]
[doc('For each restic command but not backup, as it needs additional volumes and environment variables')]
_restic-run backup_target +restic_args:
  #!/usr/bin/env nu

  let backup_target = "{{backup_target}}"

  with-env { 
    HOSTNAME: "m700"
    RESTIC_ENV_FILE: $"($backup_target).restic.env" 
  } {
    ^docker compose -f docker-compose.backup.yaml run --rm restic {{restic_args}}
  }