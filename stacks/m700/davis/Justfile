set shell := ["bash", "-eoux", "pipefail", "-c"]

set dotenv-load

help:
  just --list --list-submodules

####################################
######## DOCKER             ########
####################################

[group('docker')]
[doc('Start the stack')]
up:
  docker compose up -d --remove-orphans

[group('docker')]
[doc('Stop the stack')]
down:
  docker compose down --remove-orphans

[group('docker')]
[doc('Restart application stack')]
restart: down && up

[group('docker')]
[doc('Get logs for the application')]
logs:
  docker compose logs -f

[group("docker")]
[doc('List data of the application')]
ls-davis-data:
  just ls-volume-data davis-data

[group("docker")]
[doc('List docker volume data')]
[private]
ls-volume-data export_path:
  docker run --rm -v {{export_path}}:/data:ro alpine ls -la /data

[group('application')]
[doc('Migrate database')]
migrate:
  docker exec -it davis sh -c "APP_ENV=prod bin/console doctrine:migrations:migrate --no-interaction"

[group('application')]
[doc('Get logs for the application')]
davis-log-tail:
    docker exec -it davis tail /var/www/davis/var/log/prod.log

    ####################################
######## BACKUP             ########
####################################

[group("backup")]
cleanup-backup-data:
  rm -rf ${BACKUP_EXPORT_DATA_DIR}

[group("backup")]
prepare-backup-data:
  rm -rf ${BACKUP_EXPORT_DATA_DIR}
  mkdir -p ${BACKUP_EXPORT_DATA_DIR}
  nu prepare_backup_data.nu \
    --docker-container-name davis \
    --docker-volume-name davis-data \
    --database-name davis-database.db \
    --backup-export-data-dir ${BACKUP_EXPORT_DATA_DIR}

[group("backup")]
bbb target: 
  #!/usr/bin/env nu
  use std/log

  let target = "{{target}}"

  let hc_url = $"https://($env.HC_API)/ping/($env.HC_PING_KEY)/($env.HC_CHECK_NAME)-($target)"
  let run_id = (random uuid)

  let logfile = $"($target).backup.log"
  
  try {
    ^curl -X POST $"($hc_url)/start?rid=($run_id)"

    just prepare-backup-data

    with-env {
      GIT_SHA: (git ls-remote https://github.com/optimistic-cloud/home-ops.git HEAD | cut -f1),
      RESTIC_ENV_FILE: $"($target).restic.env"
    } { 
      if (not ($env.BACKUP_EXPORT_DATA_DIR | path exists)) {
        error make {msg: "Backup export data directory ($env.BACKUP_EXPORT_DATA_DIR) does not exist"}
      }

      ^docker compose -f docker-compose.backup.yaml run --rm backup out+err> $logfile
      ^docker compose -f docker-compose.backup.yaml run --rm forget out+err>> $logfile
      ^docker compose -f docker-compose.backup.yaml run --rm check out+err>> $logfile
    }

    if (($logfile | path exists) and ((ls $logfile | get size.0) > 0B)) {
      error make {msg: "Backup failed, log file ($logfile) is not empty"}
    }

    ^curl -X POST $"($hc_url)/0?rid=($run_id)" -H "Content-Type: text/plain" --data-binary $"@($logfile)"
  } catch { |err|
    log error $"Backup failed with error: ($err)"
    print $err >> $logfile
    ^curl -X POST $"($hc_url)/1?rid=($run_id)" -H "Content-Type: text/plain" --data-binary $"@($logfile)"
    ^curl -X POST $"($hc_url)/fail?rid=($run_id)" -H "Content-Type: text/plain" --data-binary $"@($logfile)"
  }
  # finally
  rm -f $logfile

[group("backup")]
backup +backup_targets: && cleanup-backup-data up
  bash backup.sh {{backup_targets}}

[group("backup")]
backup-py +backup_targets: && cleanup-backup-data up
  python3 backup.py {{backup_targets}}

[group("backup")]
restore backup_target snapshot_id="latest":
  #!/usr/bin/env bash
  restore_data_dir="${BACKUP_RESTORE_DATA_DIR:?BACKUP_RESTORE_DATA_DIR is required}"
  mkdir -p "${restore_data_dir}"
  just restic-restore {{backup_target}} {{snapshot_id}}

####################################
######## RESTIC             ########
####################################

[group('restic')]
[doc('Init repository')]
restic-init backup_target:
  just _restic-run {{backup_target}} init

[group('restic')]
[doc('Restore data')]
[private]
restic-restore backup_target snapshot_id:
  just _restic-run {{backup_target}} restore {{snapshot_id}} --target /restore-data

[group('restic')]
[doc('Get snapshots')]
restic-snapshots backup_target count="5":
  just _restic-run {{backup_target}} --quiet snapshots --latest {{count}}

[group('restic')]
[doc('List files in the latest snapshot')]
restic-ls backup_target snapshot_id="latest":
  just _restic-run {{backup_target}} --quiet ls {{snapshot_id}}

[group('restic')]
[doc('Get stats of the repository')]
restic-stats backup_target:
  just _restic-run {{backup_target}} stats --mode raw-data

[group('restic')]
[doc('Unlock repository')]
restic-unlock backup_target:
  just _restic-run {{backup_target}} --quiet unlock

[group('restic')]
[doc('Prune snapshots')]
restic-prune backup_target:
  just _restic-run {{backup_target}} --quiet prune

[group('restic')]
[private]
[doc('For each restic command but not backup, as it needs additional volumes and environment variables')]
_restic-run backup_target +restic_args:
  #!/usr/bin/env nu

  let backup_target = "{{backup_target}}"

  with-env { 
    HOSTNAME: "m700"
    RESTIC_ENV_FILE: $"($backup_target).restic.env" 
  } {
    ^docker compose -f docker-compose.backup.yaml run --rm restic {{restic_args}}
  }
